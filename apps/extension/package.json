{
  "name": "tasker-copilot-extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json && cp manifest.json dist/manifest.json && cp src/popup/popup.html dist/popup.html",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.7.0",
    "@typescript-eslint/parser": "^8.7.0",
    "eslint": "^9.11.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.1",
    "jsdom": "^25.0.1",
    "@types/chrome": "^0.0.287"
  },
  "dependencies": {
    "@tasker-copilot/shared": "file:../../packages/shared"
  }
}
