{
  "manifest_version": 3,
  "key": "",
  "name": "Tasker Proposal Copilot",
  "version": "0.1.0",
  "version_name": "dev",
  "description": "Analyze Tasker jobs, generate proposals, and fill forms safely.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "https://tasker-copilot.easy-wh.com/*",
    "https://tasker.com.tw/*",
    "https://www.tasker.com.tw/*"
  ],
  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://tasker.com.tw/*",
        "https://www.tasker.com.tw/*"
      ],
      "js": ["content/index.js"],
      "run_at": "document_idle"
    }
  ]
}
